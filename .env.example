# WhatsApp Cloud API — Next.js (.env.local local; en Vercel: dashboard)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_GRAPH_API_VERSION=v19.0

# Multi-número (preparación; el bot sigue usando WHATSAPP_* hasta integrar webhook)
WHATSAPP_MULTI_NUMBER_ENABLED=false
WHATSAPP_DEFAULT_OWNER=bot_principal

# Embedded Signup v3 — coexistence Jefe 1 (/conectar-whatsapp)
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v19.0
# Secreto para abrir /conectar-whatsapp?setup_token=... (solo servidor + header API)
WHATSAPP_SETUP_TOKEN=
# Opcional: redirect_uri OAuth si Meta exige coincidencia exacta con la config
# META_OAUTH_REDIRECT_URI=https://tu-dominio.com/conectar-whatsapp

# Claude (Anthropic) — tono conversacional opcional
ANTHROPIC_API_KEY=

# Supabase (server-side, service_role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CRM auth (JWT para asesores)
CRM_JWT_SECRET=cambia_esto_por_un_secreto_seguro

# Vercel Cron Jobs (re-engagement automático)
CRON_SECRET=cambia_esto_por_un_secreto_cron_seguro
